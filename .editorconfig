# EditorConfig — Brisas de Calamuchita
# https://editorconfig.org
# Mantiene consistencia de formato entre distintos editores e IDEs.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false
max_line_length = 120

[*.{yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab
