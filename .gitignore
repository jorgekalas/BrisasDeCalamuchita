# ============================================================
# .gitignore — Brisas de Calamuchita (monorepo)
# ============================================================

# --- Dependencias ---
node_modules/
**/node_modules/
.pnp
.pnp.js

# --- Variables de entorno (NUNCA subir secretos) ---
.env
.env.local
.env.development
.env.production
.env.test
**/.env
!**/.env.ejemplo

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Builds y artefactos ---
dist/
build/
out/
.next/
.cache/
.parcel-cache/
.vite/

# --- Cobertura de tests ---
coverage/
*.lcov
.nyc_output/

# --- IDE y editores ---
.vscode/
!.vscode/settings.recomendado.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# --- Sistema operativo ---
.DS_Store
Thumbs.db
desktop.ini

# --- Docker ---
# Los volumenes nombrados (brisas_mysql_data) los administra Docker
# internamente, no caen en el repo. Solo ignoramos carpetas locales
# por si alguien usa bind mounts custom.
docker/datos-mysql/
docker/datos-volumenes/
docker/mysql/logs/

# --- Base de datos local ---
*.sqlite
*.db
dump.sql
backup-*.sql

# --- Archivos temporales del proyecto ---
tmp/
temp/
*.tmp
*.bak

# --- Misceláneos ---
.eslintcache
.stylelintcache
*.tsbuildinfo
