{
  "name": "brisas-backend",
  "version": "0.1.0",
  "description": "API REST para el sistema de reservas Brisas de Calamuchita",
  "main": "src/servidor.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/servidor.js",
    "start": "node src/servidor.js",
    "iniciar": "node src/servidor.js",
    "migrar": "node scripts/runner-sql.cjs migrar",
    "semillas": "node scripts/runner-sql.cjs semillas",
    "resetear": "node scripts/runner-sql.cjs resetear",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unitarios",
    "test:e2e": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/e2e --runInBand",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch tests/unitarios",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint src tests"
  },
  "keywords": [
    "brisas-de-calamuchita",
    "reservas",
    "alquiler-turistico",
    "api-rest",
    "express",
    "mysql"
  ],
  "author": "Jorge Kalas",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.11.5",
    "nodemailer": "^6.10.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
