# =============================================================
#   MySQL — configuracion custom para Brisas de Calamuchita
# =============================================================
#   Este archivo se monta en /etc/mysql/conf.d/custom.cnf
#   y MySQL lo carga automaticamente al arrancar.
# =============================================================

[mysqld]
# --- Charset y collation por defecto ---
# Forzamos utf8mb4 en todas las conexiones y tablas nuevas
# para soportar acentos, ñ y caracteres extendidos.
character-set-server          = utf8mb4
collation-server              = utf8mb4_unicode_ci
init-connect                  = 'SET NAMES utf8mb4'

# --- Timezone ---
# Argentina (UTC-3). Hace que NOW(), CURRENT_TIMESTAMP y los
# TIMESTAMP devuelvan hora local en lugar de UTC.
default-time-zone             = '-03:00'

# --- Configuracion de SQL ---
# sql_mode estricto: rechaza datos invalidos en lugar de
# convertirlos silenciosamente (ej: si insertas un VARCHAR(80)
# con 100 caracteres, da error en lugar de cortarlo).
sql_mode                      = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

# --- Logs ---
# Habilitamos el log de queries lentas para detectar problemas
# de performance temprano. Cualquier query que tarde mas de
# 2 segundos queda registrada.
slow_query_log                = 1
slow_query_log_file           = /var/log/mysql/slow.log
long_query_time               = 2

# --- Conexiones ---
# Limite generoso para desarrollo. En produccion ajustar segun carga.
max_connections               = 100

# --- Buffers ---
# innodb_buffer_pool_size es la cache principal de InnoDB.
# Para desarrollo 256M alcanza y sobra; en produccion seria 70-80% de la RAM.
innodb_buffer_pool_size       = 256M


[client]
# Forzamos utf8mb4 tambien del lado cliente.
default-character-set         = utf8mb4


[mysql]
default-character-set         = utf8mb4
